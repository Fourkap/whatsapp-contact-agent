# Copie ce fichier vers .env puis remplis les valeurs — .env n'est jamais commité.

# Jeton lié à ton abonnement Claude Pro/Max (généré par `claude setup-token`)
CLAUDE_CODE_OAUTH_TOKEN=

# Clé API admin d'OpenWA (affichée au premier démarrage, ou via :
#   docker exec openwa-api cat /app/data/.api-key)
OPENWA_API_KEY=

# Intervalle entre deux synchronisations, en secondes (défaut : 30 min)
SYNC_INTERVAL_SECONDS=1800

# Fenêtre du premier import, en jours (0 = tout l'historique disponible)
INITIAL_WINDOW_DAYS=30

# Messages max récupérés par conversation et par synchro
HISTORY_LIMIT=100

# Optionnel : si défini, tous les appels à l'API (port 2786) devront porter
# le header X-API-Key avec cette valeur. Indispensable si tu exposes le port.
AGENT_API_KEY=
